# --- Fitbit API (https://dev.fitbit.com) ---
FITBIT_CLIENT_ID=deine_client_id_hier
FITBIT_CLIENT_SECRET=dein_client_secret_hier
FITBIT_REDIRECT_URI=http://localhost:8000/fitbit/callback

# --- Backend Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- ESP32 WLAN (nur lokal, nicht in Git) ---
WIFI_SSID=dein_wlan_name
WIFI_PASSWORD=dein_wlan_passwort

# --- SQLite Datenbank ---
DATABASE_URL=./data/iot_dashboard.db