# ========================
# Secrets & Umgebungsvariablen
# ========================
.env                # Lokale Umgebungsvariablen (API-Keys, Passwörter)
*.env               # Alle .env Dateien
!.env.example       # AUSNAHME: .env.example soll versioniert werden (als Vorlage)

# ========================
# Python
# ========================
__pycache__/        # Python Bytecode Cache (wird automatisch generiert)
*.py[cod]           # Python kompilierte Dateien (.pyc, .pyo, .pyd)
*.pyo               # Python optimierte Bytecode Dateien
*.pyd               # Python Erweiterungsmodule (Windows)
.Python             # Python Installer Verzeichnis
venv/               # Python Virtual Environment
.venv/              # Alternative Virtual Environment Bezeichnung
env/                # Alternative Environment Verzeichnis
ENV/                # Alternative Environment (Großbuchstaben)
*.egg-info/         # Python Package Metadata
dist/               # Distribution/Build-Verzeichnis (Wheel, Tarball)
build/              # Build-Verzeichnis (temporäre Dateien beim Build)
.pytest_cache/      # Pytest Cache (Testlauf-Zwischenspeicher)
*.log               # Log-Dateien (Debug, Error Logs)

# ========================
# Datenbank (lokal, nicht ins Repo)
# ========================
*.db                # SQLite Datenbank Dateien
*.sqlite            # SQLite Datenbank (alte Extension)
*.sqlite3           # SQLite3 Datenbank Dateien (aktuelle Standard)

# ========================
# VS Code
# ========================
.vscode/            # VS Code Einstellungen (lokal, personalisiert)
!.vscode/extensions.json   # AUSNAHME: Extensions-Liste soll geteilt werden
!.vscode/settings.json.example  # AUSNAHME: Beispiel-Einstellungen zur Referenz

# ========================
# CircuitPython / MicroPython
# ========================
*.mpy               # MicroPython kompilierte Dateien
CIRCUITPY/          # CircuitPython Board Mount-Punkt (wird automatisch erstellt)

# ========================
# macOS / Windows
# ========================
.DS_Store           # macOS Verzeichnis-Metadaten (versteckt)
Thumbs.db           # Windows Thumbnail Cache
desktop.ini         # Windows Desktop Einstellungen (versteckt)

# ========================
# Node (falls Frontend-Tools genutzt werden)
# ========================
node_modules/       # NPM Abhängigkeiten (werden via package.json installiert)
npm-debug.log       # NPM Debug Log-Datei
